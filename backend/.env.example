# Smart-Risk Sentinel — Backend Environment Configuration
# Copy this file to .env and fill in your local values:
#   cp .env.example .env
#
# The .env file is git-ignored — each developer keeps their own locally.

# --- PostgreSQL connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_risk_sentinel
DB_USER=postgres
DB_PASSWORD=your_password_here

# --- Flask ---
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=dev-secret-not-for-production
